config LVX_USE_DEMO_SMART_BAND_BASIC
	bool "Smart band basic LVGL demo"
	default n
	---help---
		Enable the basic smart band demo application. It follows the
		packages/demos style used by openvela native demos such as Bandx.
		The demo shows a watch face, simulated heart rate, simulated steps,
		and swipe navigation.

if LVX_USE_DEMO_SMART_BAND_BASIC

config LVX_DEMO_SMART_BAND_BASIC_PRIORITY
	int "Smart band basic task priority"
	default 100

config LVX_DEMO_SMART_BAND_BASIC_STACKSIZE
	int "Smart band basic stack size"
	default 8192

config LVX_DEMO_SMART_BAND_BASIC_LOOP_DELAY_US
	int "LVGL loop delay in microseconds"
	default 5000

config LVX_DEMO_SMART_BAND_BASIC_STANDALONE_INIT
	bool "Call lv_init() in smart_band main"
	default n
	---help---
		Enable this only when the board/simulator has not initialized LVGL
		before starting the application.

endif
